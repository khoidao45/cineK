# ===== Required secrets (must set) =====
POSTGRES_PASSWORD=replace_with_strong_postgres_password
NEO4J_PASSWORD=replace_with_strong_neo4j_password
REDIS_PASSWORD=replace_with_strong_redis_password
JWT_SECRET=replace_with_strong_jwt_secret_min_32_chars

# ===== Service credentials / names =====
POSTGRES_DB=movie_db
POSTGRES_USER=movie_user
NEO4J_USERNAME=neo4j

# ===== App runtime =====
SERVER_PORT=8080
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# ===== URLs =====
APP_BASE_URL=http://localhost:8080
OAUTH2_REDIRECT_URI=http://localhost:3000/oauth2/redirect

# ===== External integrations (optional) =====
GOOGLE_CLIENT_ID=disabled
GOOGLE_CLIENT_SECRET=disabled
SENDGRID_API_KEY=disabled
SENDGRID_FROM_EMAIL=noreply@example.com
SUPABASE_STORAGE_BASE_URL=
VIDEO_LOCAL_ROOT=videos

# Optional metadata provider (if you later integrate TMDb)
TMDB_API_KEY=
